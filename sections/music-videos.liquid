{%- comment -%}
  Music videos page — horizontal slider of video tiles.
  Each video is a block with poster image + video URL + title.
{%- endcomment -%}
<section class="main-content" id="videos">
  <div class="mv">
    <div class="mv__track-wrap" id="mvWrap">
      <ul class="mv__track" id="mvTrack">
        {%- for block in section.blocks -%}
          <li class="mv__card" {{ block.shopify_attributes }}>
            <a class="mv__artwork-link" href="#" data-video-src="{{ block.settings.video_url }}" data-video-title="{{ block.settings.title | escape }}">
              {%- if block.settings.poster -%}
                <img class="mv__artwork" src="{{ block.settings.poster | image_url: width: 700 }}" alt="{{ block.settings.title | escape }}">
              {%- endif -%}
            </a>
            <div class="mv__info window">
              <div class="border-left"></div>
              <div class="border-right"></div>
              <div class="window__titlebar">
                <span class="window__text">INFO</span>
              </div>
              <ul class="mv__desc">
                <li><span class="mv__desc-item">{{ block.settings.artist | upcase }}</span></li>
                <li><span class="mv__desc-item">{{ block.settings.title | upcase }}</span></li>
                <li><button type="button" class="mv__desc-item mv__play" data-video-src="{{ block.settings.video_url }}" data-video-title="{{ block.settings.title | escape }}">PLAY VIDEO</button></li>
              </ul>
            </div>
          </li>
        {%- endfor -%}
      </ul>
    </div>
    <div class="mv__nav">
      <div class="mv__page-counter">
        <img class="mv__counter-bg" src="{{ 'plp-counter.png' | asset_url }}" alt="">
        <span class="mv__counter-text">PAGE <span id="mvPage">1</span>/<span id="mvTotal">1</span></span>
      </div>
      <div class="mv__bar-wrap">
        <button class="mv__arrow mv__arrow--prev" id="mvPrev" aria-label="Previous"></button>
        <div class="mv__slider-bg">
          <div class="mv__slider-node" id="mvSliderNode"></div>
        </div>
        <button class="mv__arrow mv__arrow--next" id="mvNext" aria-label="Next"></button>
      </div>
    </div>
  </div>
</section>

<!-- Draggable video modal -->
<div class="vm" id="vmModal" style="display:none">
  <div class="window vm__window">
    <div class="border-left"></div>
    <div class="border-right"></div>
    <div class="window__titlebar vm__titlebar" id="vmTitlebar">
      <button class="window__close" id="vmClose" type="button" aria-label="Close"></button>
      <span class="window__text" id="vmTitle">VIDEO</span>
    </div>
    <div class="vm__body">
      <video class="vm__video" id="vmVideo" playsinline></video>
      <div class="vm__controls">
        <div class="vm__scrubber" id="vmScrubber">
          <div class="vm__scrub-track">
            <div class="vm__scrub-fill" id="vmFill"></div>
          </div>
          <div class="vm__scrub-thumb" id="vmThumb"></div>
        </div>
        <div class="vm__transport">
          <button class="player__btn player__btn--transport" id="vmPlayPause" aria-label="Play">
            <svg width="14" height="14" viewBox="0 0 12 14" fill="currentColor"><polygon points="0,0 0,14 12,7"/></svg>
          </button>
          <span class="vm__time" id="vmTime">0:00 / 0:00</span>
          <button class="player__btn vm__fs-btn" id="vmFs" aria-label="Fullscreen">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="currentColor"><path d="M0 0v5h2V2h3V0H0zm9 0v2h3v3h2V0H9zM0 9v5h5v-2H2V9H0zm12 3h-3v2h5V9h-2v3z"/></svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
(function () {
  /* Slider basics (mirrors plp logic) */
  const track   = document.getElementById('mvTrack');
  const wrap    = document.getElementById('mvWrap');
  const prevBtn = document.getElementById('mvPrev');
  const nextBtn = document.getElementById('mvNext');
  const pageEl  = document.getElementById('mvPage');
  const totalEl = document.getElementById('mvTotal');
  function getCardWidth() { const c = track.querySelector('.mv__card'); return c ? c.offsetWidth + 16 : 0; }
  function getPerPage() { return window.innerWidth <= 780 ? 1 : 3; }
  function update() {
    const items = track.querySelectorAll('.mv__card').length;
    const total = Math.max(1, Math.ceil(items / getPerPage()));
    const cardW = getCardWidth();
    const atEnd = wrap.scrollLeft + wrap.offsetWidth >= wrap.scrollWidth - 1;
    const current = atEnd ? total : (cardW > 0 ? Math.min(Math.round(wrap.scrollLeft / (cardW * getPerPage())) + 1, total) : 1);
    pageEl.textContent = current; totalEl.textContent = total;
    document.querySelector('.mv__nav').style.display = total <= 1 ? 'none' : '';
  }
  prevBtn.addEventListener('click', () => wrap.scrollBy({ left: -(getCardWidth() * getPerPage()), behavior: 'smooth' }));
  nextBtn.addEventListener('click', () => wrap.scrollBy({ left:   getCardWidth() * getPerPage(),  behavior: 'smooth' }));
  wrap.addEventListener('scroll', update);
  window.addEventListener('resize', update);
  update();

  /* Video modal — custom player (scrubber + transport + fullscreen) */
  const modal     = document.getElementById('vmModal');
  const video     = document.getElementById('vmVideo');
  const titleEl   = document.getElementById('vmTitle');
  const closeBtn  = document.getElementById('vmClose');
  const titlebar  = document.getElementById('vmTitlebar');
  const playPause = document.getElementById('vmPlayPause');
  const scrubber  = document.getElementById('vmScrubber');
  const fill      = document.getElementById('vmFill');
  const thumb     = document.getElementById('vmThumb');
  const timeEl    = document.getElementById('vmTime');
  const fsBtn     = document.getElementById('vmFs');

  const ICON_PLAY  = '<svg width="14" height="14" viewBox="0 0 12 14" fill="currentColor"><polygon points="0,0 0,14 12,7"/></svg>';
  const ICON_PAUSE = '<svg width="12" height="14" viewBox="0 0 12 14" fill="currentColor"><rect x="0" y="0" width="4" height="14"/><rect x="8" y="0" width="4" height="14"/></svg>';

  function fmt(s) {
    if (!s || isNaN(s)) return '0:00';
    const m = Math.floor(s / 60), sec = Math.floor(s % 60);
    return m + ':' + (sec < 10 ? '0' : '') + sec;
  }
  function updateScrubber() {
    if (!video.duration) return;
    const pct = video.currentTime / video.duration;
    fill.style.width = (pct * 100) + '%';
    const trackW = scrubber.offsetWidth - 20;
    thumb.style.left = (10 + pct * trackW) + 'px';
    timeEl.textContent = fmt(video.currentTime) + ' / ' + fmt(video.duration);
  }
  video.addEventListener('timeupdate', updateScrubber);
  video.addEventListener('play',  () => { playPause.innerHTML = ICON_PAUSE; });
  video.addEventListener('pause', () => { playPause.innerHTML = ICON_PLAY; });
  video.addEventListener('ended', () => { playPause.innerHTML = ICON_PLAY; });
  playPause.addEventListener('click', () => { if (video.paused) video.play(); else video.pause(); });

  let seeking = false;
  function seek(clientX) {
    const rect = scrubber.getBoundingClientRect();
    const pct = Math.max(0, Math.min(1, (clientX - rect.left) / rect.width));
    if (video.duration) video.currentTime = pct * video.duration;
    updateScrubber();
  }
  scrubber.addEventListener('mousedown', e => { e.stopPropagation(); seeking = true; seek(e.clientX); });
  document.addEventListener('mousemove', e => { if (seeking) seek(e.clientX); });
  document.addEventListener('mouseup', () => { seeking = false; });

  fsBtn.addEventListener('click', () => {
    if (video.requestFullscreen) video.requestFullscreen();
    else if (video.webkitRequestFullscreen) video.webkitRequestFullscreen();
    else if (video.webkitEnterFullscreen) video.webkitEnterFullscreen(); /* iOS */
  });

  function open(src, title) {
    if (!src) return;
    video.src = src;
    titleEl.textContent = title || 'VIDEO';
    fill.style.width = '0%';
    thumb.style.left = '10px';
    timeEl.textContent = '0:00 / 0:00';
    playPause.innerHTML = ICON_PLAY;
    modal.style.display = 'block';
    modal.classList.add('is-open');
    video.play().catch(() => {});
  }
  function close() {
    video.pause(); video.src = '';
    modal.style.display = 'none';
    modal.classList.remove('is-open');
    playPause.innerHTML = ICON_PLAY;
  }
  document.addEventListener('click', e => {
    const trig = e.target.closest('[data-video-src]');
    if (trig) { e.preventDefault(); open(trig.getAttribute('data-video-src'), trig.getAttribute('data-video-title')); }
  });
  closeBtn.addEventListener('click', close);
  document.addEventListener('keydown', e => { if (e.key === 'Escape' && modal.style.display !== 'none') close(); });
  if (window.SFRDrag) SFRDrag.wire(modal, titlebar, closeBtn);
})();
</script>

{% schema %}
{
  "name": "Music videos",
  "settings": [],
  "blocks": [
    {
      "type": "video",
      "name": "Video",
      "settings": [
        { "type": "text",         "id": "artist",    "label": "Artist" },
        { "type": "text",         "id": "title",     "label": "Title" },
        { "type": "image_picker", "id": "poster",    "label": "Poster image (portrait)" },
        { "type": "url",          "id": "video_url", "label": "Video URL (MP4)" }
      ]
    }
  ],
  "max_blocks": 24,
  "presets": [
    { "name": "Music videos", "blocks": [ { "type": "video" }, { "type": "video" }, { "type": "video" } ] }
  ]
}
{% endschema %}
