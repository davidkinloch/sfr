{%- comment -%}
  Cart page — mirrors our static "checkout" layout. The actual
  Shopify checkout is hosted, so the form posts to /checkout.
  Left side: customer info (collected once on checkout anyway, here
  it's UI shell), right side: live cart items + totals.
{%- endcomment -%}
<section class="checkout-page" id="checkout">
  <div class="checkout-page__inner">

    <form action="{{ routes.cart_url }}" method="post" id="cartForm" novalidate>

      <div class="contact-window window">
        <div class="border-left"></div>
        <div class="border-right"></div>
        <div class="window__titlebar">
          <span class="window__text">CHECK OUT</span>
        </div>
        <div class="window__content contact-window__body">

          <!-- LEFT -->
          <div class="contact-window__col contact-window__col--left">

            <div class="contact-info__header">{{ shop.name | upcase }}</div>

            <!-- Express checkout buttons (Shopify renders these via additional_checkout_buttons when supported) -->
            <div class="checkout-section">
              <div class="checkout-section__head">
                <span class="checkout-label">EXPRESS CHECK OUT OPTIONS</span>
              </div>
              {%- if additional_checkout_buttons -%}
                <div class="checkout-express additional-checkout-buttons">
                  {{ content_for_additional_checkout_buttons }}
                </div>
              {%- else -%}
                <div class="checkout-express">
                  <a class="checkout-pay-btn checkout-pay-btn--shop" href="{{ routes.cart_url }}" aria-label="Shop Pay"><span class="checkout-pay-btn__label">shop <strong>Pay</strong></span></a>
                  <a class="checkout-pay-btn checkout-pay-btn--paypal" href="{{ routes.cart_url }}" aria-label="PayPal"><span class="checkout-pay-btn__label"><em>Pay</em>Pal</span></a>
                  <a class="checkout-pay-btn checkout-pay-btn--apple" href="{{ routes.cart_url }}" aria-label="Apple Pay"><span class="checkout-pay-btn__label">&#63743; Pay</span></a>
                </div>
              {%- endif -%}
            </div>

            <!-- Contact -->
            <div class="checkout-section">
              <div class="checkout-section__head">
                <span class="checkout-label checkout-label--big">CONTACT</span>
                {%- if customer -%}
                  <span class="checkout-section__aux">LOGGED IN AS {{ customer.email | upcase }} &middot; <a class="checkout-link" href="{{ routes.account_logout_url }}">LOG OUT</a></span>
                {%- else -%}
                  <span class="checkout-section__aux">HAVE AN ACCOUNT? <a class="checkout-link" href="{{ routes.account_login_url }}">LOG IN</a></span>
                {%- endif -%}
              </div>
              <input class="checkout-input" type="text" name="checkout[email]" placeholder="EMAIL ADDRESS OR PHONE NUMBER" value="{{ customer.email }}">
              <label class="contact-form__check">
                <input type="checkbox" name="checkout[buyer_accepts_marketing]" value="1">
                <span class="contact-form__check-box" aria-hidden="true"></span>
                <span>EMAIL ME WITH NEWS AND OFFERS</span>
              </label>
            </div>

            <!-- Delivery -->
            <div class="checkout-section">
              <div class="checkout-label checkout-label--big">DELIVERY</div>
              <div class="checkout-input checkout-select">
                <span>COUNTRY / REGION</span>
                <select name="checkout[shipping_address][country]" aria-label="Country / region">
                  {%- for country in shop.enabled_currencies -%}
                    <option>{{ country.iso_code }}</option>
                  {%- endfor -%}
                  <option>UNITED STATES</option>
                  <option>UNITED KINGDOM</option>
                  <option>SPAIN</option>
                  <option>FRANCE</option>
                  <option>GERMANY</option>
                </select>
              </div>
              <div class="checkout-row-2">
                <input class="checkout-input" type="text" name="checkout[shipping_address][first_name]" placeholder="FIRST NAME">
                <input class="checkout-input" type="text" name="checkout[shipping_address][last_name]"  placeholder="LAST NAME">
              </div>
              <div class="checkout-input checkout-address">
                <input type="text" name="checkout[shipping_address][address1]" placeholder="ADDRESS">
                <button type="button" class="checkout-address__find">Find</button>
              </div>
              <a class="checkout-link" href="#">ENTER ADDRESS MANUALLY</a>
              <div class="checkout-label checkout-label--big">SHIPPING METHOD</div>
              <div class="checkout-empty">
                ENTER YOUR SHIPPING ADDRESS TO<br>
                VIEW AVAILABLE SHIPPING METHODS
              </div>
            </div>

            <input type="hidden" name="checkout" value="">
            <button type="submit" name="checkout" class="contact-form__send checkout-submit">PLACE ORDER</button>

          </div>

          <!-- RIGHT — cart items -->
          <div class="contact-window__col contact-window__col--right">

            <div class="pdp__purchase cart-summary__strip">
              <div class="pdp__price">
                <span class="pdp__price-tag cart-summary__count" id="coCount">{{ cart.item_count }}</span>
              </div>
              <div class="pdp__stock">CART ITEMS</div>
              <div class="pdp__buy">
                <a class="checkout-link cart-summary__discount" href="#" id="coDiscount">DISCOUNT CODE</a>
              </div>
            </div>

            <table class="cart-table">
              <thead>
                <tr>
                  <th>CAT NO</th>
                  <th>ITEM NAME</th>
                  <th>COST</th>
                  <th>QTY</th>
                  <th aria-label="Remove"></th>
                </tr>
              </thead>
              <tbody id="coItems">
                {%- for item in cart.items -%}
                  {%- assign cat = item.product.metafields.custom.cat_no | default: '—' -%}
                  <tr data-line="{{ forloop.index }}" data-key="{{ item.key }}">
                    <td>{{ cat }}</td>
                    <td>{{ item.product.title | upcase }}{% unless item.variant.title == 'Default Title' %} &middot; {{ item.variant.title | upcase }}{% endunless %}</td>
                    <td>{{ item.price | money_without_trailing_zeros }}</td>
                    <td>{{ item.quantity }}x</td>
                    <td>
                      <button type="button" class="cart-remove-btn" data-key="{{ item.key }}" aria-label="Remove">
                        {% render 'icon-trash' %}
                      </button>
                    </td>
                  </tr>
                {%- else -%}
                  <tr><td colspan="5" class="cart-empty">YOUR CART IS EMPTY</td></tr>
                {%- endfor -%}
              </tbody>
            </table>

            <div class="cart-totals">
              <div class="cart-totals__row"><span>SUB TOTAL</span><span id="coSub">{{ cart.items_subtotal_price | money_without_trailing_zeros }}</span></div>
              <div class="cart-totals__row"><span>SHIPPING</span><span id="coShip">CALCULATED AT CHECKOUT</span></div>
              <div class="cart-totals__row"><span>ESTIMATED TAXES</span><span id="coTax">CALCULATED AT CHECKOUT</span></div>
              {%- if cart.total_discount > 0 -%}
                <div class="cart-totals__row"><span>DISCOUNT</span><span id="coDisc">-{{ cart.total_discount | money_without_trailing_zeros }}</span></div>
              {%- endif -%}
              <div class="cart-totals__row cart-totals__row--total"><span>TOTAL</span><span id="coTotal">{{ cart.total_price | money_without_trailing_zeros }}</span></div>
            </div>

          </div>

        </div>
      </div>

    </form>

  </div>
</section>

<script>
(function () {
  /* Remove line item with /cart/change.js */
  const tbody = document.getElementById('coItems');
  if (tbody && window.SFRCart) {
    tbody.addEventListener('click', async function (e) {
      const btn = e.target.closest('.cart-remove-btn');
      if (!btn) return;
      const key = btn.getAttribute('data-key');
      btn.disabled = true;
      try {
        await SFRCart.change({ id: key, quantity: 0 });
        window.location.reload();
      } catch (err) {
        btn.disabled = false;
      }
    });
  }
})();
</script>

{% schema %}
{
  "name": "Cart",
  "settings": [],
  "presets": [
    { "name": "Cart" }
  ]
}
{% endschema %}
