{%- comment -%}
  Cart page. Checkout is Shopify-hosted (Basic plan), which collects
  email + shipping address + rates itself, so this page only shows the
  live cart and proceeds to checkout. No contact/delivery fields here —
  posting them to /cart does nothing.
  Left: account state, express buttons, PLACE ORDER. Right: items + totals.
{%- endcomment -%}
<section class="checkout-page" id="checkout">
  <div class="checkout-page__inner">

    <form action="{{ routes.cart_url }}" method="post" id="cartForm" novalidate>

      <div class="contact-window window">
        <div class="border-left"></div>
        <div class="border-right"></div>
        <div class="window__titlebar">
          <span class="window__text">CHECK OUT</span>
        </div>
        <div class="window__content contact-window__body">

          <!-- LEFT -->
          <div class="contact-window__col contact-window__col--left">

            <div class="contact-info__header">{{ shop.name | upcase }}</div>

            <!-- Account state -->
            <div class="checkout-section">
              {%- if customer -%}
                <span class="checkout-section__aux">LOGGED IN AS {{ customer.email | upcase }} &middot; <a class="checkout-link" href="{{ routes.account_logout_url }}">LOG OUT</a></span>
              {%- else -%}
                <span class="checkout-section__aux">HAVE AN ACCOUNT? <a class="checkout-link" href="{{ routes.account_login_url }}">LOG IN</a></span>
              {%- endif -%}
            </div>

            <!-- Express checkout buttons — only render when Shopify provides them -->
            {%- if additional_checkout_buttons -%}
              <div class="checkout-section">
                <div class="checkout-section__head">
                  <span class="checkout-label">EXPRESS CHECK OUT OPTIONS</span>
                </div>
                <div class="checkout-express additional-checkout-buttons">
                  {{ content_for_additional_checkout_buttons }}
                </div>
              </div>
            {%- endif -%}

            <div class="checkout-empty">
              SHIPPING, TAXES &amp; DISCOUNT CODES<br>
              ENTERED AT CHECKOUT
            </div>

            <button type="submit" name="checkout" class="contact-form__send checkout-submit"{% if cart.item_count == 0 %} disabled{% endif %}>PLACE ORDER</button>

          </div>

          <!-- RIGHT — cart items -->
          <div class="contact-window__col contact-window__col--right">

            <div class="pdp__purchase cart-summary__strip">
              <div class="pdp__price">
                <span class="pdp__price-tag cart-summary__count" id="coCount">{{ cart.item_count }}</span>
              </div>
              <div class="pdp__stock">CART ITEMS</div>
              <div class="pdp__buy"></div>
            </div>

            <table class="cart-table">
              <thead>
                <tr>
                  <th>CAT NO</th>
                  <th>ITEM NAME</th>
                  <th>COST</th>
                  <th>QTY</th>
                  <th aria-label="Remove"></th>
                </tr>
              </thead>
              <tbody id="coItems">
                {%- for item in cart.items -%}
                  {%- assign cat = item.product.metafields.custom.cat_no | default: '—' -%}
                  <tr data-line="{{ forloop.index }}" data-key="{{ item.key }}">
                    <td>{{ cat }}</td>
                    <td>{{ item.product.title | upcase }}{% unless item.variant.title == 'Default Title' %} &middot; {{ item.variant.title | upcase }}{% endunless %}</td>
                    <td>{{ item.price | money_without_trailing_zeros }}</td>
                    <td>{{ item.quantity }}x</td>
                    <td>
                      <button type="button" class="cart-remove-btn" data-key="{{ item.key }}" aria-label="Remove">
                        {% render 'icon-trash' %}
                      </button>
                    </td>
                  </tr>
                {%- else -%}
                  <tr><td colspan="5" class="cart-empty">YOUR CART IS EMPTY</td></tr>
                {%- endfor -%}
              </tbody>
            </table>

            <div class="cart-totals">
              <div class="cart-totals__row"><span>SUB TOTAL</span><span id="coSub">{{ cart.items_subtotal_price | money_without_trailing_zeros }}</span></div>
              <div class="cart-totals__row"><span>SHIPPING</span><span id="coShip">CALCULATED AT CHECKOUT</span></div>
              <div class="cart-totals__row"><span>ESTIMATED TAXES</span><span id="coTax">CALCULATED AT CHECKOUT</span></div>
              {%- if cart.total_discount > 0 -%}
                <div class="cart-totals__row"><span>DISCOUNT</span><span id="coDisc">-{{ cart.total_discount | money_without_trailing_zeros }}</span></div>
              {%- endif -%}
              <div class="cart-totals__row cart-totals__row--total"><span>TOTAL</span><span id="coTotal">{{ cart.total_price | money_without_trailing_zeros }}</span></div>
            </div>

          </div>

        </div>
      </div>

    </form>

  </div>
</section>

<script>
(function () {
  /* Remove line item with /cart/change.js */
  const tbody = document.getElementById('coItems');
  if (tbody && window.SFRCart) {
    tbody.addEventListener('click', async function (e) {
      const btn = e.target.closest('.cart-remove-btn');
      if (!btn) return;
      const key = btn.getAttribute('data-key');
      btn.disabled = true;
      try {
        await SFRCart.change({ id: key, quantity: 0 });
        window.location.reload();
      } catch (err) {
        btn.disabled = false;
      }
    });
  }
})();
</script>

{% schema %}
{
  "name": "Cart",
  "settings": [],
  "presets": [
    { "name": "Cart" }
  ]
}
{% endschema %}
