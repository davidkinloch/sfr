<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#D3D0D4">
  {%- comment -%}
    Homepage renders the records PLP and would duplicate /collections/records.
    Point canonical at the collection URL so Google consolidates ranking there.
  {%- endcomment -%}
  {%- if template == 'index' -%}
    <link rel="canonical" href="{{ shop.url }}{{ collections.records.url | default: '/collections/records' }}">
  {%- else -%}
    <link rel="canonical" href="{{ canonical_url }}">
  {%- endif -%}
  {%- comment -%} Favicon / app icons — defaults to login-avatar.png, overridable via the theme Favicon setting {%- endcomment -%}
  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" sizes="32x32" href="{{ settings.favicon | image_url: width: 32 }}">
    <link rel="icon" type="image/png" sizes="16x16" href="{{ settings.favicon | image_url: width: 16 }}">
    <link rel="apple-touch-icon" sizes="180x180" href="{{ settings.favicon | image_url: width: 180 }}">
  {%- else -%}
    <link rel="icon" type="image/png" sizes="32x32" href="{{ 'icon-32.png' | asset_url }}">
    <link rel="icon" type="image/png" sizes="192x192" href="{{ 'icon-192.png' | asset_url }}">
    <link rel="apple-touch-icon" sizes="180x180" href="{{ 'icon-180.png' | asset_url }}">
  {%- endif -%}
  <link rel="manifest" href="{{ 'manifest.json' | asset_url }}">

  <title>
    {{ page_title }}
    {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
    {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
  </title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}

  {{ content_for_header }}

  <link rel="stylesheet" href="{{ 'theme.css' | asset_url }}">
</head>
<body class="template-{{ template | replace: '.', '-' | handle }}">

  {% render 'header' %}

  <main role="main">
    {{ content_for_layout }}
  </main>

  {% render 'footer' %}

  {% render 'login-popup' %}
  {% render 'menu-modal' %}
  {% render 'music-player' %}

  <script src="{{ 'theme.js' | asset_url }}" defer></script>
</body>
</html>
