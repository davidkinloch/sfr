<section class="contact-page">
  <div class="contact-page__inner">
    <div class="contact-window window">
      <div class="border-left"></div>
      <div class="border-right"></div>
      <div class="window__titlebar"><span class="window__text">{{ blog.title | upcase }}</span></div>
      <div class="window__content contact-window__body">
        <div class="contact-window__col" style="grid-column:1/-1; max-width:100%;">
          <ul class="menu-modal__list">
            {%- for article in blog.articles -%}
              <li>
                <a class="menu__item" href="{{ article.url }}">
                  {{ article.title | upcase }} — {{ article.published_at | date: '%Y-%m-%d' }}
                </a>
              </li>
            {%- endfor -%}
          </ul>
          {{ paginate | default_pagination }}
        </div>
      </div>
    </div>
  </div>
</section>
